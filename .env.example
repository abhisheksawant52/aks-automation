# Azure authentication (used by DefaultAzureCredential for CI / service principals)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me

# aks_automation settings (AKS_ prefix maps to Settings fields)
AKS_RESOURCE_GROUP=aks-automation-rg
AKS_LOCATION=eastus
AKS_CLUSTER_NAME=aks-automation-cluster
AKS_NODE_COUNT=3
AKS_VM_SIZE=Standard_D2s_v3
# AKS_KUBERNETES_VERSION=1.30.0
# AKS_DNS_PREFIX=aks-automation
AKS_LOG_LEVEL=INFO
